rules_version = '2';

// Paste this into Firebase Console > Firestore Database > Rules, then
// click Publish. See FIREBASE_SETUP.md for the full walkthrough.
service cloud.firestore {
  match /databases/{database}/documents {

    match /creators/{applicationId} {

      // Anyone can submit a new application from join.html (public form),
      // but only as a brand-new "pending" doc — they can't set themselves
      // to "approved" or edit/delete existing applications. A signed-in
      // admin can also create a document directly with any status (used
      // by the admin.html "import starter creators" button).
      allow create: if request.auth != null
                    || (request.resource.data.status == 'pending'
                        && request.resource.data.name is string
                        && request.resource.data.name.size() > 0
                        && request.resource.data.email is string
                        && request.resource.data.bio is string);

      // Anyone can read approved creators (creators.html public directory).
      allow read: if resource.data.status == 'approved';

      // Only a signed-in admin (created in Firebase Authentication) can
      // read pending/rejected applications, or approve/reject/delete one.
      allow read, update, delete: if request.auth != null;
    }
  }
}
